##### Adding Left Items #####
#
##### Aerospace specific #####

sketchybar --add event aerospace_workspace_change

# Wait for aerospace to be ready (max 5 seconds)
for i in {1..10}; do
    if pgrep -x "AeroSpace" > /dev/null && aerospace list-workspaces --all 2>/dev/null | grep -q .; then
        break
    fi
    sleep 0.5
done

# Get all workspace IDs
all_workspaces=$(aerospace list-workspaces --all)

# Define the complete QWERTY layout order
qwerty_order=(
    "1" "2" "3" "4" "5" "6" "7" "8" "9" "0"
    "q" "w" "e" "r" "t" "y" "u" "i" "o" "p"
    "a" "s" "d" "f" "g" "h" "j" "k" "l"
    "z" "x" "c" "v" "b" "n" "m"
)

# Sort the workspaces based on the QWERTY order
sorted_workspaces=()

# First add workspaces in our defined QWERTY order
for key in "${qwerty_order[@]}"; do
    if echo "$all_workspaces" | grep -q "^$key$"; then
        sorted_workspaces+=("$key")
    fi
done

# Then add any remaining workspaces that weren't in our predefined order
for sid in $all_workspaces; do
    if ! printf '%s\n' "${sorted_workspaces[@]}" | grep -q "^$sid$"; then
        sorted_workspaces+=("$sid")
    fi
done

# Create sketchybar items for all workspaces in the sorted order
    # background.color=0x99eb6f92 \
    # background.color=0x44ffffff \

for sid in "${sorted_workspaces[@]}"; do
    sketchybar --add item space.$sid left \
        --subscribe space.$sid aerospace_workspace_change \
        --set space.$sid \
        label.color=0xffe0def4 \
        background.border_color=0xff524f67 \
        background.border_width=0 \
        background.color=0xffebbcba \
        background.corner_radius=5 \
        background.height=20 \
        background.drawing=off \
        label="$sid" \
        click_script="aerospace workspace $sid" \
        script="$CONFIG_DIR/plugins/aerospace.sh $sid"
done

