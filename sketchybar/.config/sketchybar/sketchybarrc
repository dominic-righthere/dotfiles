#!/bin/bash
# SketchyBar — Rose Pine Moon, modular. Managed in the dotfiles repo (stow package).
#
# Structure / how modules load:
#   sketchybarrc   – this file: bar shell, events, loads ENABLED modules
#   settings.sh    – module registry + on/off state (the "extensions" layer)
#   colors.sh      – Rose Pine Moon palette + tokens
#   items/<m>.sh   – one file per module; sourced ONLY when that module is enabled
#                    (disabled module = never added = zero runtime cost). NB: items
#                    are sourced into THIS file's scope — they rely on colors.sh,
#                    settings.sh, $FONT, $SYSTEM_ITEMS and module_enabled already
#                    being set here (this rc is the composition root).
#   plugins/<x>.sh – update/click scripts EXECUTED by sketchybar at runtime
#                    (they source colors.sh themselves; $NAME/$SENDER come from sketchybar)
#
# Toggle modules from the gear popup (far right) or zen via ⌥⇧Z. State persists
# in ~/.cache/sketchybar/modules.state (outside the repo, survives reload/reboot).

export CONFIG_DIR="$HOME/.config/sketchybar"
export PLUGIN_DIR="$CONFIG_DIR/plugins"
ITEM_DIR="$CONFIG_DIR/items"
source "$CONFIG_DIR/colors.sh"
source "$CONFIG_DIR/settings.sh"

export FONT="Hack Nerd Font"

##### Bar — flush solid black so the notch dissolves into it #####
sketchybar --bar \
  height=44 position=top y_offset=0 margin=0 corner_radius=0 \
  blur_radius=0 color=$BAR_COLOR border_width=0 notch_width=0 shadow=off \
  padding_left=8 padding_right=8

##### Defaults — applied to every item unless overridden #####
default=(
  padding_left=4
  padding_right=4
  # Hack only ships Regular/Bold (no Semibold/Medium) — using a weight Hack
  # doesn't have makes macOS silently fall back to SF Pro. Keep both Bold so
  # every label + icon renders in true Hack Nerd Font.
  icon.font="$FONT:Bold:14.0"
  label.font="$FONT:Bold:13.0"
  icon.color=$TEXT
  label.color=$TEXT
  icon.padding_left=6
  icon.padding_right=4
  label.padding_left=4
  label.padding_right=6
  background.height=26
  background.corner_radius=8
  popup.background.color=$SURFACE
  popup.background.corner_radius=10
  popup.background.border_width=2
  popup.background.border_color=$IRIS
  popup.blur_radius=20
)
sketchybar --default "${default[@]}"

##### Custom events #####
sketchybar --add event aerospace_workspace_change \
           --add event aerospace_mode \
           --add event zen_toggle

# Wait for aerospace to be ready (max 5s) before querying workspaces
for i in {1..10}; do
  if pgrep -x "AeroSpace" >/dev/null && aerospace list-workspaces --all 2>/dev/null | grep -q .; then
    break
  fi
  sleep 0.5
done

# Metric modules append their item name here; the system island wraps them.
SYSTEM_ITEMS=()

##### Left modules (left-to-right) #####
module_enabled layout     && source "$ITEM_DIR/layout.sh"
module_enabled workspaces && source "$ITEM_DIR/workspaces.sh"

##### Right modules (added rightmost-first: control center is the far corner) #####
module_enabled control_center && source "$ITEM_DIR/control_center.sh"
module_enabled clock          && source "$ITEM_DIR/clock.sh"
module_enabled battery        && source "$ITEM_DIR/battery.sh"
module_enabled audio          && source "$ITEM_DIR/audio.sh"
module_enabled cpu            && source "$ITEM_DIR/cpu.sh"
module_enabled input_source   && source "$ITEM_DIR/input_source.sh"
module_enabled lyrics         && source "$ITEM_DIR/lyrics.sh"

##### System island — wraps whichever metric items registered #####
if [ ${#SYSTEM_ITEMS[@]} -gt 0 ]; then
  sketchybar --add bracket system "${SYSTEM_ITEMS[@]}" \
             --set system \
                   background.color=$ISLAND_BG \
                   background.corner_radius=10 \
                   background.border_width=2 \
                   background.border_color=$ISLAND_BORDER
fi

##### Force all scripts to run once on load #####
sketchybar --update
