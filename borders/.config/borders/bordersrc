#!/bin/bash
# JankyBorders config — draws a border around the active window.
# Auto-loaded by `borders` on startup (launched via aerospace after-startup-command).
# Colors: 0xAARRGGBB. Theme: Rose Pine Moon (matches tmux).
options=(
    style=round
    width=6.0
    hidpi=off
    active_color=0xffc4a7e7    # Rose Pine iris
    inactive_color=0x00000000  # no border when unfocused
)
borders "${options[@]}"
